FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Declare all NEXT_PUBLIC_ build args
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_COMPANY_NAME
ARG NEXT_PUBLIC_COMPANY_SHORT_NAME
ARG NEXT_PUBLIC_COMPANY_TAGLINE
ARG NEXT_PUBLIC_COMPANY_DESCRIPTION
ARG NEXT_PUBLIC_COMPANY_EMAIL
ARG NEXT_PUBLIC_COMPANY_PHONE
ARG NEXT_PUBLIC_COMPANY_WHATSAPP
ARG NEXT_PUBLIC_COMPANY_ADDRESS
ARG NEXT_PUBLIC_COMPANY_CITY
ARG NEXT_PUBLIC_COMPANY_COUNTRY
ARG NEXT_PUBLIC_COMPANY_OPENING_HOURS
ARG NEXT_PUBLIC_COMPANY_LATITUDE
ARG NEXT_PUBLIC_COMPANY_LONGITUDE
ARG NEXT_PUBLIC_DEFAULT_KEYWORDS
ARG NEXT_PUBLIC_LINKEDIN_URL
ARG NEXT_PUBLIC_FACEBOOK_URL
ARG NEXT_PUBLIC_INSTAGRAM_URL
ARG NEXT_PUBLIC_TWITTER_URL
ARG NEXT_PUBLIC_GA_ID
ARG NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION

# Set as ENV so Next.js build can read them
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_COMPANY_NAME=$NEXT_PUBLIC_COMPANY_NAME
ENV NEXT_PUBLIC_COMPANY_SHORT_NAME=$NEXT_PUBLIC_COMPANY_SHORT_NAME
ENV NEXT_PUBLIC_COMPANY_TAGLINE=$NEXT_PUBLIC_COMPANY_TAGLINE
ENV NEXT_PUBLIC_COMPANY_DESCRIPTION=$NEXT_PUBLIC_COMPANY_DESCRIPTION
ENV NEXT_PUBLIC_COMPANY_EMAIL=$NEXT_PUBLIC_COMPANY_EMAIL
ENV NEXT_PUBLIC_COMPANY_PHONE=$NEXT_PUBLIC_COMPANY_PHONE
ENV NEXT_PUBLIC_COMPANY_WHATSAPP=$NEXT_PUBLIC_COMPANY_WHATSAPP
ENV NEXT_PUBLIC_COMPANY_ADDRESS=$NEXT_PUBLIC_COMPANY_ADDRESS
ENV NEXT_PUBLIC_COMPANY_CITY=$NEXT_PUBLIC_COMPANY_CITY
ENV NEXT_PUBLIC_COMPANY_COUNTRY=$NEXT_PUBLIC_COMPANY_COUNTRY
ENV NEXT_PUBLIC_COMPANY_OPENING_HOURS=$NEXT_PUBLIC_COMPANY_OPENING_HOURS
ENV NEXT_PUBLIC_COMPANY_LATITUDE=$NEXT_PUBLIC_COMPANY_LATITUDE
ENV NEXT_PUBLIC_COMPANY_LONGITUDE=$NEXT_PUBLIC_COMPANY_LONGITUDE
ENV NEXT_PUBLIC_DEFAULT_KEYWORDS=$NEXT_PUBLIC_DEFAULT_KEYWORDS
ENV NEXT_PUBLIC_LINKEDIN_URL=$NEXT_PUBLIC_LINKEDIN_URL
ENV NEXT_PUBLIC_FACEBOOK_URL=$NEXT_PUBLIC_FACEBOOK_URL
ENV NEXT_PUBLIC_INSTAGRAM_URL=$NEXT_PUBLIC_INSTAGRAM_URL
ENV NEXT_PUBLIC_TWITTER_URL=$NEXT_PUBLIC_TWITTER_URL
ENV NEXT_PUBLIC_GA_ID=$NEXT_PUBLIC_GA_ID
ENV NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=$NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000
CMD ["node", "server.js"]
